{
  "author": "Roland Milto (https://roland.milto.de/)",
  "contributors": [
    "Roland Milto (https://roland.milto.de/)"
  ],
  "homepage": "https://roland.milto.de/projekte/",
  "name": "nodejs-project-template",
  "version": "0.0.0",
  "license": "GPL-3.0-or-later",
  "description": "Empty Node.js project template for TypeScript with strict rules for ESLint, Prettier, JSDoc, and more.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/roland-milto/nodejs-project-template.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/roland-milto/nodejs-project-template/issues"
  },
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./register-global": {
      "types": "./dist/register-global.d.ts",
      "import": "./dist/register-global.mjs",
      "default": "./dist/register-global.mjs"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "sideEffects": [
    "./dist/register-global.mjs"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/standard-version": "^7.1.3",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.8.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-todo": "^0.1.0",
    "standard-version": "^9.5.0",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2"
  },
  "scripts": {
    "build": "npm run format-code && npm run build:cdn-version && npm run build:npm-version",
    "build:cdn-version": "tsdown --name CDN --clean --dts false --sourcemap false --minify && node -e \"fs.copyFileSync('./dist/index.mjs', './dist/index.min.mjs')\"",
    "build:npm-version": "tsdown src/index.ts --name NPM --dts true --sourcemap true --unbundle true --no-clean",
    "build:watch": "tsdown --name DEV --unbundle true --no-clean --watch",
    "create-changelog": "standard-version",
    "format-code": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\" \"tests/**/*.ts\"",
    "prebuild": "node prebuild/add_information_here.mjs",
    "prepublishOnly": "npm run build",
    "publish": "npm run create-changelog && npm publish --access public --tag latest"
  },
  "tsdown": {
    "treeshake": false
  },
  "jsdelivr": "./dist/index.min.mjs",
  "unpkg": "./dist/index.min.mjs",
  "keywords": [
    "nodejs",
    "nodejs project template",
    "project template"
  ],
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "eslint-plugin-jsdoc": "^62.9.0"
  }
}